{
  "name": "@agora/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ../../scripts/run-node-with-root-env.mjs dist/index.js",
    "start:stdio": "node ../../scripts/run-node-with-root-env.mjs dist/index.js --stdio",
    "test": "node --import tsx --test $(find src/tests -type f -name '*.test.ts' | sort)"
  },
  "dependencies": {
    "@agora/agent-runtime": "workspace:*",
    "@agora/chain": "workspace:*",
    "@agora/common": "workspace:*",
    "@agora/db": "workspace:*",
    "@agora/ipfs": "workspace:*",
    "@agora/scorer": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.19.2"
  }
}
