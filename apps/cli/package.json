  },
  "dependencies": {
    "@agora/agent-runtime": "workspace:*",
    "@agora/common": "workspace:*",
    "@agora/ipfs": "workspace:*",
    "@agora/db": "workspace:*",
    "@agora/chain": "workspace:*",
    "@supabase/supabase-js": "^2.97.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "viem": "^2.21.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8",
    "@agora/scorer": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.19.2"
  }
}
