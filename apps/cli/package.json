{
  "name": "@agora/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "agora": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "node --import tsx src/index.ts",
