{
  "name": "@agora/contracts",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test --no-match-path 'test/fork/*' -vv",
    "test:invariant": "forge test --match-contract AgoraInvariantTest --no-match-path 'test/fork/*' -vv",
    "test:fork": "forge test --match-path 'test/fork/*.t.sol' -vv",
    "coverage": "forge coverage --ir-minimum --no-match-path 'test/fork/*' --report summary --report lcov",
    "coverage:check": "pnpm coverage && node ../../scripts/check-contract-coverage.mjs lcov.info",
    "deploy:local": "forge script script/Deploy.s.sol --rpc-url http://localhost:8545 --broadcast",
    "deploy:local-mock-usdc": "forge script script/DeployLocalMockUSDC.s.sol --rpc-url http://localhost:8545 --broadcast",
    "install:deps": "forge install foundry-rs/forge-std@v1.8.2 openzeppelin/openzeppelin-contracts@v5.0.2"
  }
}
