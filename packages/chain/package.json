{
  "name": "@agora/chain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/tests/challenge-definition.test.ts src/tests/indexer-status-projection.ts && node --import tsx src/tests/chain-integration.ts",
    "indexer": "node ../../scripts/run-node-with-root-env.mjs --runtime-surface=indexer dist/indexer.js",
    "indexer:local": "node dist/indexer.js"
  },
  "dependencies": {
    "@agora/common": "workspace:*",
    "@agora/db": "workspace:*",
    "@agora/ipfs": "workspace:*",
    "viem": "^2.21.15",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.19.2"
  }
}
