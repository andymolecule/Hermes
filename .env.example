# Chain
# Keep these values canonical per environment.
# API, indexer, worker, CLI, and NEXT_PUBLIC_* web values must all point to the same factory/token pair.
NODE_ENV=development
AGORA_RPC_URL=https://sepolia.base.org
AGORA_CHAIN_ID=84532
AGORA_PRIVATE_KEY=0x...
AGORA_ORACLE_KEY=0x...
AGORA_ORACLE_ADDRESS=0x...
AGORA_SOLVER_WALLET_BACKEND=private_key
AGORA_CDP_API_KEY_ID=
AGORA_CDP_API_KEY_SECRET=
AGORA_CDP_WALLET_SECRET=
AGORA_CDP_ACCOUNT_NAME=
AGORA_CDP_ACCOUNT_ADDRESS=
AGORA_FACTORY_ADDRESS=0x...
AGORA_USDC_ADDRESS=0x...
AGORA_TREASURY_ADDRESS=0x...

# IPFS
AGORA_PINATA_JWT=ey...
AGORA_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
# Network hardening for IPFS fetches
AGORA_IPFS_FETCH_TIMEOUT_MS=30000
AGORA_IPFS_FETCH_MAX_ATTEMPTS=3
AGORA_IPFS_FETCH_RETRY_BASE_MS=500

# Database (Supabase)
AGORA_SUPABASE_URL=https://xxx.supabase.co
AGORA_SUPABASE_ANON_KEY=ey...
AGORA_SUPABASE_SERVICE_KEY=ey...
# Direct Postgres connection used only by destructive bootstrap/reset commands.
# Runtime services should not need this value.
AGORA_SUPABASE_ADMIN_DB_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# API
# On Vercel, AGORA_API_URL must be the backend API origin. Do not point it at
# the web origin, or the web app's same-origin /api proxy will recurse/fail.
AGORA_API_URL=http://localhost:3000
AGORA_WEB_URL=http://localhost:3100
AGORA_API_PORT=3000
# Internal worker validation bridge used by the API to preflight sealed
# submission CIDs before creating submission intents.
AGORA_WORKER_INTERNAL_URL=http://localhost:3400
AGORA_WORKER_INTERNAL_TOKEN=
# Master key used to encrypt stored agent webhook signing secrets at rest.
AGORA_AGENT_NOTIFICATION_MASTER_KEY=
# Comma-separated list of allowed browser origins for API CORS
# Example: http://localhost:3100,https://agora-web.vercel.app
AGORA_CORS_ORIGINS=http://localhost:3100
# Deterministic authoring compiler
AGORA_AUTHORING_COMPILER_DRY_RUN_TIMEOUT_MS=180000
# Optional shared secret for internal authoring operator endpoints such as
# callback sweep / maintenance. Set this on the API service and any internal
# caller that needs to trigger those endpoints.
AGORA_AUTHORING_OPERATOR_TOKEN=

# Scorer execution backend
# Local development defaults to local_docker. Production should prefer remote_http
# so the worker orchestrator can run beside the API in the shared Fly runtime
# while scorer containers execute on a separate Docker-capable host.
AGORA_SCORER_EXECUTOR_BACKEND=local_docker
AGORA_SCORER_EXECUTOR_URL=http://localhost:3200
AGORA_SCORER_EXECUTOR_TOKEN=
# Executor service (used only by apps/executor)
AGORA_EXECUTOR_PORT=3200
AGORA_EXECUTOR_AUTH_TOKEN=

# Lifecycle smoke E2E (optional)
# The local deterministic smoke and external CLI smoke default to the current
# zero-hour testnet dispute window. Raise this only when you explicitly want to
# exercise delayed-settlement behavior against a different contract policy.
AGORA_E2E_SCORER_IMAGE=ghcr.io/andymolecule/gems-match-scorer:v1
AGORA_E2E_DEADLINE_MINUTES=10
AGORA_E2E_DISPUTE_WINDOW_HOURS=0
AGORA_E2E_ENABLE_TIME_TRAVEL=1
AGORA_E2E_MAX_FINALIZE_WAIT_SECONDS=600

# Contract fork tests (optional)
# Prefer a pinned Base Sepolia block so fork runs stay deterministic in CI.
AGORA_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
AGORA_FORK_BLOCK=

# Submission sealing
# Active public key served to clients for local sealing.
AGORA_SUBMISSION_SEAL_KEY_ID=
AGORA_SUBMISSION_SEAL_PUBLIC_KEY_PEM=
# Optional explicit file-backed alternative. The runtime loader reads this file and
# populates AGORA_SUBMISSION_SEAL_PUBLIC_KEY_PEM before services start.
AGORA_SUBMISSION_SEAL_PUBLIC_KEY_PEM_FILE=
# Active worker private key. Keep for simple single-key setups.
AGORA_SUBMISSION_OPEN_PRIVATE_KEY_PEM=
# Optional explicit file-backed alternative. The runtime loader reads this file and
# populates AGORA_SUBMISSION_OPEN_PRIVATE_KEY_PEM before services start.
AGORA_SUBMISSION_OPEN_PRIVATE_KEY_PEM_FILE=
# Optional rotation support for historical sealed submissions.
# JSON object mapping kid -> PKCS#8 PEM private key.
AGORA_SUBMISSION_OPEN_PRIVATE_KEYS_JSON=
# Optional explicit file-backed alternative for the JSON keyring above.
AGORA_SUBMISSION_OPEN_PRIVATE_KEYS_JSON_FILE=
# Worker heartbeat used to prove live scoring readiness back to the API.
AGORA_WORKER_HEARTBEAT_MS=30000
AGORA_WORKER_HEARTBEAT_STALE_MS=90000
# Internal worker validation HTTP port (used only by the worker service).
AGORA_WORKER_INTERNAL_PORT=3400
# Optional bind host for the worker's internal validation server. Leave unset
# for local development. Fly private networking should bind to
# fly-local-6pn so the API can reach the worker over 6PN internal DNS.
AGORA_WORKER_INTERNAL_HOST=
# Optional stable worker runtime id. Set when running multiple scoring workers
# in one environment so each runtime writes to a unique heartbeat row.
AGORA_WORKER_RUNTIME_ID=
# Canonical hosted release identity. By default the runtime derives this from
# the platform commit SHA and keeps it aligned with AGORA_RUNTIME_VERSION.
AGORA_RELEASE_ID=
# Source git SHA for the same release. This is provenance; the short SHA remains
# the primary runtime fence.
AGORA_RELEASE_GIT_SHA=
# Back-compat runtime fence. Hosted deploys should leave this aligned to the
# short commit SHA; local development may still fall back to dev/git metadata.
AGORA_RUNTIME_VERSION=
# Force hosted runtime startup to reject placeholder or non-canonical release
# metadata sources.
AGORA_EXPECT_RELEASE_METADATA=
# Optional read token for GHCR digest resolution when official scorer packages
# are not public yet.
AGORA_GHCR_TOKEN=

# Indexer
# Number of confirmations to wait before indexing logs (reorg safety)
AGORA_INDEXER_CONFIRMATION_DEPTH=3
# API/indexer lag health thresholds
AGORA_INDEXER_LAG_WARN_BLOCKS=20
AGORA_INDEXER_LAG_CRITICAL_BLOCKS=120
AGORA_INDEXER_ACTIVE_CURSOR_WINDOW_MS=900000
# Optional override when bootstrapping a new factory or replaying from a known block
AGORA_INDEXER_START_BLOCK=
# Retry/backoff tuning for transient RPC or IPFS failures during indexing
AGORA_INDEXER_RETRY_MAX_ATTEMPTS=8
AGORA_INDEXER_RETRY_BASE_DELAY_MS=30000
# Rolling replay window for projection reconciliation and shallow reorg recovery
AGORA_INDEXER_REPLAY_WINDOW_BLOCKS=2000
# In production, set true once official GHCR scorer packages are public so
# Agora resolves stable version tags to digests and rejects mutable refs.
AGORA_REQUIRE_PINNED_PRESET_DIGESTS=true
# Score-job lease timeout (must exceed longest expected worker heartbeat gap)
AGORA_WORKER_JOB_LEASE_MS=3600000
# Worker control-loop timing
AGORA_WORKER_POLL_MS=15000
AGORA_WORKER_FINALIZE_SWEEP_MS=60000
# Delay before retrying jobs that are waiting on tx propagation/reconciliation
AGORA_WORKER_POST_TX_RETRY_MS=30000
# Delay before retrying jobs blocked on scorer infrastructure (executor, registry, pull, daemon)
AGORA_WORKER_INFRA_RETRY_MS=300000

# Logging
AGORA_LOG_LEVEL=info
AGORA_SENTRY_DSN=
AGORA_SENTRY_ENVIRONMENT=
AGORA_SENTRY_TRACES_SAMPLE_RATE=0

# Frontend (Next.js requires NEXT_PUBLIC_ prefix for browser-side vars)
# These should match the server-side AGORA_* values above for the same environment.
NEXT_PUBLIC_AGORA_API_URL=http://localhost:3000
NEXT_PUBLIC_AGORA_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_AGORA_USDC_ADDRESS=0x...
NEXT_PUBLIC_AGORA_CHAIN_ID=84532
NEXT_PUBLIC_AGORA_RPC_URL=https://sepolia.base.org

# Feature policy (v0 core mode)
# Keep false in production v0 unless intentionally enabling non-core experiments.
AGORA_ENABLE_NON_CORE_FEATURES=false

# x402 (optional, off by default)
# Effective only when AGORA_ENABLE_NON_CORE_FEATURES=true
AGORA_X402_ENABLED=false
AGORA_X402_REPORT_ONLY=false
AGORA_X402_FACILITATOR_URL=https://x402.org/facilitator
AGORA_X402_NETWORK=eip155:84532
