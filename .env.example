# Chain
# Keep these values canonical per environment.
# API, indexer, worker, CLI, and NEXT_PUBLIC_* web values must all point to the same factory/token pair.
HERMES_RPC_URL=https://sepolia.base.org
HERMES_CHAIN_ID=84532
HERMES_PRIVATE_KEY=0x...
HERMES_ORACLE_KEY=0x...
HERMES_FACTORY_ADDRESS=0x...
HERMES_USDC_ADDRESS=0x...
HERMES_TREASURY_ADDRESS=0x...

# IPFS
HERMES_PINATA_JWT=ey...
HERMES_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
# Network hardening for IPFS fetches
HERMES_IPFS_FETCH_TIMEOUT_MS=30000
HERMES_IPFS_FETCH_MAX_ATTEMPTS=3
HERMES_IPFS_FETCH_RETRY_BASE_MS=500

# Database (Supabase)
HERMES_SUPABASE_URL=https://xxx.supabase.co
HERMES_SUPABASE_ANON_KEY=ey...
HERMES_SUPABASE_SERVICE_KEY=ey...

# API
HERMES_API_URL=http://localhost:3000
HERMES_API_PORT=3000
# Comma-separated list of allowed browser origins for API CORS
# Example: http://localhost:3100,https://hermes-web.vercel.app
HERMES_CORS_ORIGINS=http://localhost:3100

# Indexer
# Number of confirmations to wait before indexing logs (reorg safety)
HERMES_INDEXER_CONFIRMATION_DEPTH=3
# In production, set true to reject non-pinned preset containers (:latest)
HERMES_REQUIRE_PINNED_PRESET_DIGESTS=false

# MCP
HERMES_MCP_PORT=3001

# Logging
HERMES_LOG_LEVEL=info

# Frontend (Next.js requires NEXT_PUBLIC_ prefix for browser-side vars)
# These should match the server-side HERMES_* values above for the same environment.
NEXT_PUBLIC_HERMES_API_URL=http://localhost:3000
NEXT_PUBLIC_HERMES_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_HERMES_USDC_ADDRESS=0x...
NEXT_PUBLIC_HERMES_CHAIN_ID=84532
NEXT_PUBLIC_HERMES_RPC_URL=https://sepolia.base.org

# Feature policy (v0 core mode)
# Keep false in production v0 unless intentionally enabling non-core experiments.
HERMES_ENABLE_NON_CORE_FEATURES=false
# Optional non-core features (effective only when HERMES_ENABLE_NON_CORE_FEATURES=true)
HERMES_ENABLE_SCORE_PREVIEW=false
HERMES_MCP_ALLOW_REMOTE_PRIVATE_KEYS=false

# x402 (optional, off by default)
# Effective only when HERMES_ENABLE_NON_CORE_FEATURES=true
HERMES_X402_ENABLED=false
HERMES_X402_REPORT_ONLY=false
HERMES_X402_FACILITATOR_URL=https://x402.org/facilitator
HERMES_X402_NETWORK=eip155:84532
