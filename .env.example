# Chain
# Keep these values canonical per environment.
# API, indexer, worker, CLI, and NEXT_PUBLIC_* web values must all point to the same factory/token pair.
AGORA_RPC_URL=https://sepolia.base.org
AGORA_CHAIN_ID=84532
AGORA_PRIVATE_KEY=0x...
AGORA_ORACLE_KEY=0x...
AGORA_ORACLE_ADDRESS=0x...
AGORA_FACTORY_ADDRESS=0x...
AGORA_USDC_ADDRESS=0x...
AGORA_TREASURY_ADDRESS=0x...

# IPFS
AGORA_PINATA_JWT=ey...
AGORA_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
# Network hardening for IPFS fetches
AGORA_IPFS_FETCH_TIMEOUT_MS=30000
AGORA_IPFS_FETCH_MAX_ATTEMPTS=3
AGORA_IPFS_FETCH_RETRY_BASE_MS=500

# Database (Supabase)
AGORA_SUPABASE_URL=https://xxx.supabase.co
AGORA_SUPABASE_ANON_KEY=ey...
AGORA_SUPABASE_SERVICE_KEY=ey...

# API
AGORA_API_URL=http://localhost:3000
AGORA_API_PORT=3000
# Comma-separated list of allowed browser origins for API CORS
# Example: http://localhost:3100,https://agora-web.vercel.app
AGORA_CORS_ORIGINS=http://localhost:3100

# Submission sealing
# Active public key served to clients for local sealing.
AGORA_SUBMISSION_SEAL_KEY_ID=
AGORA_SUBMISSION_SEAL_PUBLIC_KEY_PEM=
# Active worker private key. Keep for simple single-key setups.
AGORA_SUBMISSION_OPEN_PRIVATE_KEY_PEM=
# Optional rotation support for historical sealed submissions.
# JSON object mapping kid -> PKCS#8 PEM private key.
AGORA_SUBMISSION_OPEN_PRIVATE_KEYS_JSON=
# Worker heartbeat used to prove live scoring readiness back to the API.
AGORA_WORKER_HEARTBEAT_MS=30000
AGORA_WORKER_HEARTBEAT_STALE_MS=90000
# Optional stable worker runtime id. Set when running multiple scoring workers
# on the same host so each runtime writes to a unique heartbeat row.
AGORA_WORKER_RUNTIME_ID=

# Indexer
# Number of confirmations to wait before indexing logs (reorg safety)
AGORA_INDEXER_CONFIRMATION_DEPTH=3
# Optional override when bootstrapping a new factory or replaying from a known block
AGORA_INDEXER_START_BLOCK=
# Retry/backoff tuning for transient RPC or IPFS failures during indexing
AGORA_INDEXER_RETRY_MAX_ATTEMPTS=8
AGORA_INDEXER_RETRY_BASE_DELAY_MS=30000
# Rolling replay window for projection reconciliation and shallow reorg recovery
AGORA_INDEXER_REPLAY_WINDOW_BLOCKS=2000
# In production, set true once official GHCR scorer packages are public so
# Agora resolves stable version tags to digests and rejects mutable refs.
AGORA_REQUIRE_PINNED_PRESET_DIGESTS=false
# Score-job lease timeout (must exceed longest expected worker heartbeat gap)
AGORA_WORKER_JOB_LEASE_MS=3600000
# Delay before retrying jobs that are waiting on tx propagation/reconciliation
AGORA_WORKER_POST_TX_RETRY_MS=30000
# Delay before retrying jobs blocked on scorer infrastructure (registry, pull, daemon)
AGORA_WORKER_INFRA_RETRY_MS=300000

# MCP
AGORA_MCP_PORT=3001

# Logging
AGORA_LOG_LEVEL=info

# Frontend (Next.js requires NEXT_PUBLIC_ prefix for browser-side vars)
# These should match the server-side AGORA_* values above for the same environment.
NEXT_PUBLIC_AGORA_API_URL=http://localhost:3000
NEXT_PUBLIC_AGORA_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_AGORA_USDC_ADDRESS=0x...
NEXT_PUBLIC_AGORA_CHAIN_ID=84532
NEXT_PUBLIC_AGORA_RPC_URL=https://sepolia.base.org

# Feature policy (v0 core mode)
# Keep false in production v0 unless intentionally enabling non-core experiments.
AGORA_ENABLE_NON_CORE_FEATURES=false
# Optional non-core features (effective only when AGORA_ENABLE_NON_CORE_FEATURES=true)
AGORA_MCP_ALLOW_REMOTE_PRIVATE_KEYS=false

# x402 (optional, off by default)
# Effective only when AGORA_ENABLE_NON_CORE_FEATURES=true
AGORA_X402_ENABLED=false
AGORA_X402_REPORT_ONLY=false
AGORA_X402_FACILITATOR_URL=https://x402.org/facilitator
AGORA_X402_NETWORK=eip155:84532
